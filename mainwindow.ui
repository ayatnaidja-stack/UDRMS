        <item row="2" column="0"><widget class="QLabel" name="lblLunch"><property name="text"><string>Lunch:</string></property></widget></item>
        <item row="2" column="1"><widget class="QLineEdit" name="lineLunch"/></item>

        <item row="3" column="0"><widget class="QLabel" name="lblDinner"><property name="text"><string>Dinner:</string></property></widget></item>
        <item row="3" column="1"><widget class="QLineEdit" name="lineDinner"/></item>

        <item row="4" column="0">
         <widget class="QPushButton" name="btnSetMenu"><property name="text"><string>Set Menu</string></property></widget>
        </item>
        <item row="4" column="1">
         <widget class="QPushButton" name="btnViewMenu"><property name="text"><string>View Menu</string></property></widget>
        </item>
       </layout>
      </widget>

      <!-- ===================== FILE TAB ===================== -->
      <widget class="QWidget" name="tabFile">
       <attribute name="title"><string>File</string></attribute>
       <layout class="QVBoxLayout" name="vboxFile">
        <item><widget class="QPushButton" name="btnSave"><property name="text"><string>Save Data to File</string></property></widget></item>
        <item><widget class="QPushButton" name="btnLoad"><property name="text"><string>Load Data from File</string></property></widget></item>
       </layout>
      </widget>

     </widget>
    </item>

    <!-- ===================== OUTPUT BOX (shared, below tabs) ===================== -->
    <item>
     <widget class="QLabel" name="lblOutput"><property name="text"><string>Output:</string></property></widget>
    </item>
    <item>
     <widget class="QTextEdit" name="textOutput">
      <property name="readOnly"><bool>true</bool></property>
